<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCafeteria.ViewModels"
        x:Class="MiniCafeteria.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Cafeteria POS v2.0" Background="#2c3e50">

    <Window.Styles>
        <Style Selector="Button.menuItem">
            <Setter Property="Height" Value="82"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="*, 360">
        <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="20">
            <Border Grid.Row="0" Background="#32465a" CornerRadius="14" Padding="14">
                <StackPanel Spacing="12">
                    <TextBlock Text="MENU DOMINICANO" FontSize="24" FontWeight="Bold" Foreground="White"/>

                    <TextBox Text="{Binding BuscarTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="Buscar producto..."
                             Height="38"
                             FontSize="15"
                             Background="#eaf1f7"
                             Foreground="#2c3e50"
                             BorderBrush="#c5d3df"
                             CornerRadius="10"/>

                    <TextBlock Text="BEBIDAS" FontWeight="Bold" Foreground="#d7e3ef"/>
                    <ItemsControl ItemsSource="{Binding BebidasFiltradas}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="menuItem"
                                        Width="150"
                                        Command="{Binding DataContext.AgregarProductoCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding .}"
                                        Background="{Binding ColorFondo}"
                                        BorderBrush="{Binding ColorBorde}">
                                    <Grid RowDefinitions="*,Auto" Margin="2">
                                        <TextBlock Text="{Binding Nombre}" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Grid.Row="1" Background="#22ffffff" CornerRadius="8" Padding="6,2">
                                            <TextBlock Text="{Binding Precio, StringFormat='${0:N0}'}" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="COMIDAS Y SNACKS" FontWeight="Bold" Foreground="#d7e3ef" Margin="0,6,0,0"/>
                    <ItemsControl ItemsSource="{Binding ComidasFiltradas}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="menuItem"
                                        Width="150"
                                        Command="{Binding DataContext.AgregarProductoCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding .}"
                                        Background="{Binding ColorFondo}"
                                        BorderBrush="{Binding ColorBorde}">
                                    <Grid RowDefinitions="*,Auto" Margin="2">
                                        <TextBlock Text="{Binding Nombre}" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Grid.Row="1" Background="#22ffffff" CornerRadius="8" Padding="6,2">
                                            <TextBlock Text="{Binding Precio, StringFormat='${0:N0}'}" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#3a4f64" CornerRadius="14" Padding="14" Margin="0,20,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="LISTA DE ITEMS" FontWeight="Bold" Foreground="#d9e2ec" Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding ListaFactura}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,70,100,100,40" Margin="0,4">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Nombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"
                                             Watermark="Descripcion"/>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding CantidadTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             Margin="8,0,0,0"
                                             Watermark="Cant"/>

                                    <TextBox Grid.Column="2"
                                             Text="{Binding PrecioUnitarioTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             Margin="8,0,0,0"
                                             Watermark="Precio"/>

                                    <TextBlock Grid.Column="3" Text="{Binding Subtotal, StringFormat='${0:N2}'}"
                                               VerticalAlignment="Center" FontWeight="Bold" Foreground="#ffb3ab"
                                               Margin="8,0,0,0"/>

                                    <Button Grid.Column="4"
                                            Content="X"
                                            Command="{Binding DataContext.EliminarItemCommand, ElementName=RootWindow}"
                                            CommandParameter="{Binding .}"
                                            Margin="8,0,0,0"
                                            Background="#e74c3c"
                                            Foreground="White"
                                            CornerRadius="6"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="20,0,0,20" Margin="10,10,0,10">
            <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="18">
                <TextBlock Grid.Row="0" Text="DETALLE DE VENTA" FontWeight="Bold" Foreground="#95a5a6" Margin="0,0,0,10"/>

                <Border Grid.Row="1" Background="#f8f9fa" CornerRadius="10" Padding="10">
                    <StackPanel Spacing="6" VerticalAlignment="Top">
                        <TextBlock Text="Resumen de cobro" FontWeight="SemiBold" Foreground="#7f8c8d"/>
                        <TextBlock Text="Edita los items en la lista izquierda" FontSize="12" Foreground="#95a5a6"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Spacing="10" Margin="0,20,0,0">
                    <Separator/>
                    <Grid ColumnDefinitions="*,*">
                        <TextBlock Text="TOTAL:" FontSize="28" FontWeight="Black" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalVentaActual, StringFormat='${0:N2}'}"
                                   FontSize="28" FontWeight="Black" HorizontalAlignment="Right" Foreground="#e74c3c"/>
                    </Grid>

                    <TextBox Text="{Binding MontoRecibido}" Watermark="Efectivo recibido..." Height="45" FontSize="18"/>

                    <Border Background="#f1c40f" Padding="10" CornerRadius="8">
                        <TextBlock Text="{Binding Cambio, StringFormat='Cambio: ${0:N2}'}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="20"/>
                    </Border>
                </StackPanel>

                <Button Grid.Row="3" Content="FINALIZAR Y COBRAR" Command="{Binding FinalizarVentaCommand}"
                        Background="#27ae60" Foreground="White" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" Height="50" FontWeight="Bold" Margin="0,15,0,0" CornerRadius="8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
